# Metro (React Native's bundler) doesn't follow pnpm's symlink-based node_modules
# layout reliably. Shamefully-hoist=true makes pnpm install transitive deps
# directly into node_modules/, like npm/yarn do — Metro then finds everything.
# Expo's monorepo guide recommends this for pnpm setups.
# Trade-off: we lose pnpm's strict dependency isolation. Acceptable here.
shamefully-hoist=true
