# apps/api/.env.example — committed template. Copy to apps/api/.env (gitignored)
# and fill in real values. The hook blocks edits to .env directly, by design.

NODE_ENV=development
PORT=3000
LOG_LEVEL=debug

# App connection — uses app_user (subject to RLS, the right role for normal API traffic).
DATABASE_URL=postgres://app_user:app_user_dev@localhost:5432/knuteloop_dev

# Setup-only connection — superuser, used ONLY by scripts/dev-setup.ts to
# drop/create the dev database. Never used by the running API. Adjust password
# to match your local Postgres install.
SUPERUSER_DATABASE_URL=postgres://postgres:postgres@localhost:5432/postgres

# Dev-only JWT secret for HS256 signing/verification. Production swaps to RS256
# with Entra-validated tokens — this var becomes unused. Min 32 chars.
JWT_DEV_SECRET=local-dev-secret-rotate-before-any-prod-use-32+chars

# Real auth (Entra ID) — not configured yet. Comes in its own step.
# JWT_ISSUER=https://api.knuteloop.no
# JWT_AUDIENCE=knuteloop-app
# OIDC_JWKS_URL=https://api.knuteloop.no/.well-known/jwks.json
