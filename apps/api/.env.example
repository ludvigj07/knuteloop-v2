# apps/api/.env.example — committed template. Copy to apps/api/.env (gitignored) and fill in real values.

NODE_ENV=development
PORT=3000
LOG_LEVEL=debug

# Database — local Postgres for dev. Will switch to Aiven Helsinki for prod.
# Connect as app_user (subject to RLS), NOT as postgres superuser.
DATABASE_URL=postgres://app_user:app_user_dev@localhost:5432/knuteloop_dev

# Auth — not configured yet. Will be set up in a separate step.
# JWT_ISSUER=https://api.knuteloop.no
# JWT_AUDIENCE=knuteloop-app
# OIDC_JWKS_URL=https://api.knuteloop.no/.well-known/jwks.json

# Storage — not used yet.
# BUNNY_STORAGE_ZONE=knuteloop-dev
# BUNNY_STORAGE_KEY=
# BUNNY_CDN_HOSTNAME=knuteloop-dev.b-cdn.net

# Observability — optional.
# SENTRY_DSN=
