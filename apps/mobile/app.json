{
  "expo": {
    "name": "Knuteloop",
    "slug": "knuteloop",
    "version": "0.0.1",
    "orientation": "portrait",
    "scheme": "knuteloop",
    "userInterfaceStyle": "light",
    "ios": {
      "bundleIdentifier": "no.knuteloop.app",
      "supportsTablet": true
    },
    "android": {
      "package": "no.knuteloop.app"
    },
    "web": {
      "bundler": "metro"
    },
    "newArchEnabled": true,
    "plugins": ["expo-router"],
    "experiments": {
      "typedRoutes": true
    }
  }
}
