# apps/mobile/.env.example — committed template. Copy to apps/mobile/.env
# (gitignored) and replace the placeholder values.

# Where the local Hono backend lives. Depends on how you run the app:
#   - Expo Web:           http://localhost:3000
#   - iOS Simulator:      http://localhost:3000
#   - Android Emulator:   http://10.0.2.2:3000
#   - Physical phone:     http://<YOUR_LAN_IP>:3000 (run `ipconfig` to find it)
EXPO_PUBLIC_API_URL=http://localhost:3000

# Dev-only JWT issued by the API. Refresh with `pnpm --filter @knuteloop/api dev:token`
# and paste here. TTL is 15 min — re-run when you get 401s.
# This will go away when real auth (Entra ID) is wired up.
EXPO_PUBLIC_DEV_TOKEN=paste-token-from-pnpm-dev-token-here
